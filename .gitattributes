# 文本文件自动规范化
* text=auto

# 明确指定文本文件使用 LF
*.py       text eol=lf
*.js       text eol=lf
*.vue      text eol=lf
*.ts       text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.html     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.sh       text eol=lf
Dockerfile text eol=lf
*.env      text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# 二进制文件不转换
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.pdf      binary
*.zip      binary
*.db       binary
*.db-shm   binary
*.db-wal   binary
