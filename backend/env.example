# ============================================
# Bobi艺术·学员管理系统 环境变量配置
# 复制此文件为 .env 并修改配置
# ============================================

# 生产环境必填：使用 `openssl rand -hex 32` 生成
SECRET_KEY=your-very-secret-key-change-in-production-please-use-openssl-rand-hex-32

# 是否启用认证中间件（生产环境必须为 true）
ENABLE_AUTH_MIDDLEWARE=true

# JWT 访问令牌过期时间（分钟），建议 60-120
ACCESS_TOKEN_EXPIRE_MINUTES=120

# 数据库连接（SQLite）
DATABASE_URL=sqlite:///data/app.db

# 时区
TZ=Asia/Shanghai